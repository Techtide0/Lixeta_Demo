{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "Node",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@models/*": ["packages/models/src/*"],
      "@rules/*": ["packages/rules-engine/src/*"],
      "@iso/*": ["packages/iso-builder/src/*"]
    }
  }
}
