# Copy this file to .env and fill in values for your environment.
# .env is gitignored — never commit secrets.

NODE_ENV=development
PORT=4000

# Comma-separated list of allowed CORS origins.
# Production example: https://your-frontend.onrender.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Auth — set REQUIRE_AUTH=true and provide API_KEY_HASH if you want key-based auth.
REQUIRE_AUTH=false
API_KEY_HASH=

# Rate limiting
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# Revenue currency (ISO 4217)
REVENUE_CURRENCY=NGN
